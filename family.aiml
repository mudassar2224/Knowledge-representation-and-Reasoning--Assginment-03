  <pattern>WHO ARE THE COUSINS OF *</pattern>
  <template>Fetching cousins of <star/> from the knowledge base.</template>
</category>
<category>
  <pattern>COUSINS OF *</pattern>
  <template><srai>WHO ARE THE COUSINS OF <star/></srai></template>
</category>

<!-- =========================================================
     SPOUSE / MARRIED
     ========================================================= -->
<category>
  <pattern>WHO IS * WIFE</pattern>
  <template>Checking wife of <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * HUSBAND</pattern>
  <template>Checking husband of <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * MARRIED TO</pattern>
  <template>Checking spouse of <star/> in the knowledge base.</template>
</category>

<!-- =========================================================
     LIST QUERIES
     ========================================================= -->
<category>
  <pattern>WHO LIVES IN *</pattern>
  <template>Fetching family members who live in <star/> from the knowledge base.</template>
</category>
<category>
  <pattern>LIST ALL MEMBERS</pattern>
  <template>Fetching all family members from the knowledge base.</template>
</category>
<category>
  <pattern>WHO ARE THE MALE MEMBERS</pattern>
  <template>Fetching all male members from the knowledge base.</template>
</category>
<category>
  <pattern>WHO ARE THE FEMALE MEMBERS</pattern>
  <template>Fetching all female members from the knowledge base.</template>
</category>

</aiml>
