<!-- =========================================================
     CITY / LOCATION PATTERNS
     ========================================================= -->
<category>
  <pattern>WHERE DOES * LIVE</pattern>
  <template>Checking city for <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHERE IS * FROM</pattern>
  <template><srai>WHERE DOES <star/> LIVE</srai></template>
</category>
<category>
  <pattern>WHAT CITY DOES * LIVE IN</pattern>
  <template><srai>WHERE DOES <star/> LIVE</srai></template>
</category>

<!-- =========================================================
     EASTERN RELATION PATTERNS
     ========================================================= -->
<category>
  <pattern>WHO IS * CHACHA</pattern>
  <template>Fetching chacha (father s brother) of <star/> from the knowledge base.</template>
</category>
<category>
  <pattern>CHACHA OF *</pattern>
  <template><srai>WHO IS <star/> CHACHA</srai></template>
</category>
<category>
  <pattern>WHO IS * PHOOPHI</pattern>
  <template>Looking up phoophi (father s sister) of <star/>.</template>
</category>
<category>
  <pattern>WHO IS * MAAMU</pattern>
  <template>Looking up maamu (mother s brother) of <star/>.</template>
</category>
<category>
  <pattern>WHO IS * KHALA</pattern>
  <template>Looking up khala (mother s sister) of <star/>.</template>
</category>

<!-- =========================================================
     IN-LAW PATTERNS
     ========================================================= -->
<category>
  <pattern>WHO IS * FATHER IN LAW</pattern>
  <template>Checking father-in-law of <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * MOTHER IN LAW</pattern>
  <template>Checking mother-in-law of <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * BROTHER IN LAW</pattern>
  <template>Checking brother-in-law of <star/> in the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * SISTER IN LAW</pattern>
  <template>Checking sister-in-law of <star/> in the knowledge base.</template>
</category>

<!-- =========================================================
     ANCESTOR / DESCENDANT PATTERNS
     ========================================================= -->
<category>
  <pattern>WHO ARE THE ANCESTORS OF *</pattern>
  <template>Running ancestor query for <star/> in the Prolog knowledge base.</template>
</category>
<category>
  <pattern>ANCESTORS OF *</pattern>
  <template><srai>WHO ARE THE ANCESTORS OF <star/></srai></template>
</category>
<category>
  <pattern>WHO ARE THE DESCENDANTS OF *</pattern>
  <template>Running descendant query for <star/> in the Prolog knowledge base.</template>
</category>

<!-- =========================================================
     YES/NO RELATION PATTERNS
     ========================================================= -->
<category>
  <pattern>IS * AN ANCESTOR OF *</pattern>
  <template>Let me check if <star/> is an ancestor of <star index="2"/> using Prolog logic.</template>
</category>
<category>
  <pattern>IS * RELATED TO *</pattern>
  <template>Checking if <star/> and <star index="2"/> are blood relatives in the KB.</template>
</category>
<category>
  <pattern>ARE * AND * RELATED</pattern>
  <template><srai>IS <star/> RELATED TO <star index="2"/></srai></template>
</category>

<!-- =========================================================
     PROFILE PATTERNS
     ========================================================= -->
<category>
  <pattern>TELL ME ABOUT *</pattern>
  <template>Fetching full profile of <star/> from the family knowledge base.</template>
</category>
<category>
  <pattern>ALL ABOUT *</pattern>
  <template><srai>TELL ME ABOUT <star/></srai></template>
</category>
<category>
  <pattern>PROFILE OF *</pattern>
  <template><srai>TELL ME ABOUT <star/></srai></template>
</category>

<!-- =========================================================
     UNCLE / AUNT / COUSIN
     ========================================================= -->
<category>
  <pattern>WHO IS * UNCLE</pattern>
  <template>Looking up uncle of <star/> from the knowledge base.</template>
</category>
<category>
  <pattern>WHO IS * AUNT</pattern>
  <template>Looking up aunt of <star/> from the knowledge base.</template>
</category>
